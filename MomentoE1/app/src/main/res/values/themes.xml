<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.M1" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Colores principales de la UCC -->
        <item name="colorPrimary">@color/ucc_green</item>
        <item name="colorPrimaryVariant">@color/ucc_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/ucc_orange</item>
        <item name="colorSecondaryVariant">@color/ucc_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Estado y fondo -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/ucc_green</item>
        <item name="android:windowBackground">@color/ucc_light_gray</item>
    </style>

    <style name="Theme.M1" parent="Base.Theme.M1" />
</resources>