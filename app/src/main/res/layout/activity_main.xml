<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/ucc_light_gray">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/title_main"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/ucc_blue"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_nombre"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:boxStrokeColor="@color/ucc_green"
            app:hintTextColor="@color/ucc_green">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_nombre"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_codigo"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/til_nombre"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:boxStrokeColor="@color/ucc_green"
            app:hintTextColor="@color/ucc_green">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_codigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_codigo"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_programa_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_programa"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="@color/ucc_blue"
            app:layout_constraintTop_toBottomOf="@id/til_codigo"
            app:layout_constraintStart_toStartOf="parent"/>

        <Spinner
            android:id="@+id/sp_programa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:background="@android:drawable/btn_dropdown"
            app:layout_constraintTop_toBottomOf="@id/tv_programa_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_modalidad_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_modalidad"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="@color/ucc_blue"
            app:layout_constraintTop_toBottomOf="@id/sp_programa"
            app:layout_constraintStart_toStartOf="parent"/>

        <RadioGroup
            android:id="@+id/rg_modalidad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_modalidad_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rb_presencial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/ucc_green"
                android:text="@string/rb_presencial"/>

            <RadioButton
                android:id="@+id/rb_virtual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/ucc_green"
                android:text="@string/rb_virtual"
                android:layout_marginStart="24dp"/>
        </RadioGroup>

        <TextView
            android:id="@+id/tv_certificados_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_certificados"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="@color/ucc_blue"
            app:layout_constraintTop_toBottomOf="@id/rg_modalidad"
            app:layout_constraintStart_toStartOf="parent"/>

        <CheckBox
            android:id="@+id/cb_constancia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:buttonTint="@color/ucc_green"
            android:text="@string/cb_constancia"
            app:layout_constraintTop_toBottomOf="@id/tv_certificados_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <CheckBox
            android:id="@+id/cb_notas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:buttonTint="@color/ucc_green"
            android:text="@string/cb_notas"
            app:layout_constraintTop_toBottomOf="@id/cb_constancia"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <CheckBox
            android:id="@+id/cb_pazsalvo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:buttonTint="@color/ucc_green"
            android:text="@string/cb_pazsalvo"
            app:layout_constraintTop_toBottomOf="@id/cb_notas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <CheckBox
            android:id="@+id/cb_matricula"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:buttonTint="@color/ucc_green"
            android:text="@string/cb_matricula"
            app:layout_constraintTop_toBottomOf="@id/cb_pazsalvo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <CheckBox
            android:id="@+id/cb_promedio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:buttonTint="@color/ucc_green"
            android:text="@string/cb_promedio"
            app:layout_constraintTop_toBottomOf="@id/cb_matricula"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_urgente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_urgente"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cb_promedio"
            app:layout_constraintStart_toStartOf="parent"/>

        <Button
            android:id="@+id/btn_resumen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/ucc_green"
            android:text="@string/btn_resumen"
            android:padding="14dp"
            android:textAllCaps="true"
            app:layout_constraintTop_toBottomOf="@id/sw_urgente"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>